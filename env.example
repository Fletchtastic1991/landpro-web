# ─────────────────────────────────────────────────────────────────────────────
# LandPro Web — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Mapbox
# Get this from: account.mapbox.com → Tokens
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Python Intelligence API (local development)
# This is your landpro-intelligence FastAPI service
VITE_INTELLIGENCE_API_URL=http://localhost:8000

# Python Intelligence API (production — set this when deployed)
# VITE_INTELLIGENCE_API_URL=https://your-railway-or-render-url.com
